# Applied Leverage live site runtime contract
# Copy to .env.local for local dev. Production values should be set in Vercel.

# Public checkout URL for the workbook offer.
# Leave blank to keep the workbook in manual-request mode.
NEXT_PUBLIC_WORKBOOK_CHECKOUT_URL=

# Lifecycle delivery contract used by the intake routes.
# Kit is the preferred provider when configured; FormSubmit remains fallback.
KIT_API_KEY=
KIT_ASSESSMENT_FORM_ID=
KIT_DIAGNOSTIC_FORM_ID=
KIT_ASSESSMENT_TAG_ID=
KIT_DIAGNOSTIC_TAG_ID=
KIT_MANUAL_HEAVY_TAG_ID=
KIT_SCALE_READY_TAG_ID=
KIT_FALLBACK_TO_FORMSUBMIT=true
